# ==============================
# SC Report - Environment Config
# ==============================
# วิธีใช้: copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ถูกต้อง
#   cp .env.example .env

# --- Google Cloud / BigQuery ---
GCP_PROJECT_ID=sc-ai-uat
BQ_DATASET_ID=SCReport
BQ_AUTH_TABLE=AuthenByMenu

# --- URL สาธารณะของ Cloud Run (ใส่หลัง deploy แล้วได้ URL) ---
# ตัวอย่าง: https://screport-xxxx-uc.a.run.app
PUBLIC_BASE_URL=https://YOUR-CLOUD-RUN-URL.a.run.app

# --- (Optional) ใช้สำหรับทดสอบในเครื่องเท่านั้น ---
# CURRENT_USER_EMAIL=test@scasset.com
